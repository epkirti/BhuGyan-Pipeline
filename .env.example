# ---- Database (local Docker by default; swap for Supabase pooler URL in prod) ----
DATABASE_URL=postgresql://bhugyan:bhugyan@localhost:5433/bhugyan

# ---- Redis (Upstash in prod; local docker for dev) ----
REDIS_URL=redis://localhost:6379/0

# ---- LLM (Groq). If unset, pipelines use a deterministic offline STUB. ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Embeddings. If sentence-transformers is not installed, a hash-based ----
# ---- deterministic fallback embedder is used so dedup still runs offline. ----
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ---- Pipeline thresholds (match the report) ----
DEDUPE_SIMILARITY_THRESHOLD=0.95
PLACE_RESOLVE_SCORE_CUTOFF=85

# ---- Logging ----
LOG_LEVEL=INFO
RUN_LOG_DIR=./run_logs
